# Copy to .env.local and fill in.

# Public — sent to the browser. Safe.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Server-only — NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=ey...

# If set, the admin signup form requires this exact code to create an
# account. If unset, signups are CLOSED — add admins via the Supabase
# dashboard instead. Recommended in production.
ADMIN_SIGNUP_INVITE_CODE=replace-with-a-long-random-string

# If set, enables /api/cron/cleanup which hard-deletes soft-deleted media
# older than 7 days. Vercel cron sends this as a Bearer header
# automatically when configured. Use 32+ random chars (e.g. openssl rand -hex 32).
CRON_SECRET=

# Optional: used when generating QR codes / share links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
